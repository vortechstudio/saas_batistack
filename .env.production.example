# ========================================
# BatiStack SaaS - Configuration Production
# ========================================

# Application
APP_NAME="BatiStack SaaS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://batistack.ovh
APP_DOMAIN=batistack.ovh

# Base de données
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mapu6796_saas_batistack
DB_USERNAME=mapu6796_root
DB_PASSWORD=rbU89a-4

# Cache et Sessions (Redis recommandé pour la production)
BROADCAST_DRIVER=log
CACHE_DRIVER=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Configuration Mail (OBLIGATOIRE pour la production)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@votre-domaine.com
MAIL_FROM_NAME="${APP_NAME}"

# Stripe (Configuration des paiements)
STRIPE_KEY=pk_live_
STRIPE_SECRET=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# Configuration de sécurité
BCRYPT_ROUNDS=12
SANCTUM_STATEFUL_DOMAINS=votre-domaine.com
SESSION_SECURE_COOKIE=true

# Logs et Monitoring
LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# Configuration Filament
FILAMENT_DOMAIN=votre-domaine.com
FILAMENT_PATH=admin

# Configuration des assets
VITE_APP_NAME="${APP_NAME}"

# Configuration de sauvegarde (optionnel)
BACKUP_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=batistack-backups

# Configuration de monitoring (optionnel)
SENTRY_LARAVEL_DSN=
NEW_RELIC_LICENSE_KEY=

# Configuration de stockage de fichiers (optionnel)
FILESYSTEM_CLOUD=s3
AWS_BUCKET_PUBLIC=batistack-public

# Configuration de CDN (optionnel)
CDN_URL=https://cdn.votre-domaine.com

# Configuration de la mise en cache avancée
MEMCACHED_HOST=127.0.0.1

# Configuration des notifications push (optionnel)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu

# Configuration de recherche (optionnel)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Configuration de géolocalisation (optionnel)
GOOGLE_MAPS_API_KEY=

# Configuration de stockage de documents (optionnel)
DOCUMENT_STORAGE_DISK=s3
DOCUMENT_STORAGE_PATH=documents

# Configuration de la compression d'images (optionnel)
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_QUALITY=85

# Configuration des limites de taux
RATE_LIMIT_API=60
RATE_LIMIT_LOGIN=5

# Configuration de maintenance
MAINTENANCE_SECRET=

# Configuration de télémétrie (optionnel)
TELESCOPE_ENABLED=false

# Configuration de débogage (TOUJOURS false en production)
DEBUGBAR_ENABLED=false
QUERY_DETECTOR_ENABLED=false

# ========================================
# NOTES IMPORTANTES POUR LA PRODUCTION :
# ========================================
# 1. Générez une nouvelle APP_KEY avec : php artisan key:generate
# 2. Configurez OBLIGATOIREMENT les paramètres de base de données
# 3. Configurez OBLIGATOIREMENT les paramètres SMTP
# 4. Utilisez des mots de passe forts et uniques
# 5. Activez HTTPS et configurez SESSION_SECURE_COOKIE=true
# 6. Configurez les sauvegardes automatiques
# 7. Configurez le monitoring et les alertes
# 8. Testez toutes les fonctionnalités avant la mise en ligne
# ========================================
